{
  "name": "@kojihq/lens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Claude Code local usage analyzer CLI",
  "license": "MIT",
  "bin": {
    "koji-lens": "./dist/index.js"
  },
  "files": [
