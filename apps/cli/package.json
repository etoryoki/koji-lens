    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "@kojihq/core": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
