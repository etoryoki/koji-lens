{
  "name": "koji-lens",
  "version": "0.0.0",
  "private": true,
  "description": "Claude Code local usage analyzer - ローカル・ファースト",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
